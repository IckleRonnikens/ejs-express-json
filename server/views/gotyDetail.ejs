<%# Import the header%>
<%- include('templates/header'); -%>
<%# /Import the header%>
<style>header {display:none}</style>
<section class="goty-details" id="gotydetails">
  <div class="container">
      <%# Gamers Detail %>

      <h1><%- gotyDetail.shortname %> Winner: <%= gotyDetail.title %></h1><hr />
            <div class="row">
              <div class="col-sm-3">
                <a href="./<%= gotyDetail.shortname %>">
                  <img class="w-100" src="<%= gotyDetail.image %>" alt="Photo of <%= gotyDetail.title %>" />
                  </a>
                  <table class="table table-striped w-100">

                    <tbody>
                      <tr>
                        <th scope="row">Developer:</th>
                        <td><strong><%= gotyDetail.developer %></strong></td>
                      </tr>
                      <tr>
                        <th scope="row">Publisher:</th>
                        <td><strong><%- gotyDetail.publisher %></strong></td>
                      </tr>
                      <tr>
                        <th scope="row">Genre:</th>
                        <td><strong><%- gotyDetail.genre %></strong></td>
                      </tr>
                      <tr>
                        <th scope="row">Date:</th>
                        <td><strong><%- gotyDetail.releasedate %></strong></td>
                      </tr>
                      </tbody>
                  </table>

              </div>

              <div class="col-sm-6 ">
                <p class="text-justify"><%- gotyDetail.description %></p>
              </div>

              <div class="col-sm-3 text-center">
                <p>Honourable Mentions</p><hr />
                <div class="row">
                  <div class="col-sm-6">
                    <img class="w-100 zoom" src="/images/boxart/<%- gotyDetail.second %>.jpg" alt="Photo of <%= gotyDetail.second %>"/>
                  </div>
                  <div class="col-sm-6">
                    <img class="w-100 zoom" src="/images/boxart/<%- gotyDetail.third %>.jpg" alt="Photo of <%= gotyDetail.third %>"/>

                  </div>
                </div>

              </div>

            </div>
            
          </section>



<%# /Gamers Detail %>


<%# Import the footer %>
<%- include('templates/footer'); -%>
<%# /Import the footer %>