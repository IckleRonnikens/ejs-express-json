<%# Import the header%>
<%- include('templates/header'); -%>
<%# /Import the header%>

<section class="artistsdetails" id="artistdetails">
  <div class="container" >
      <%# Artists Details %>
      <h1 class="text-center mt-5"><a href="./<%= artist.shortname %>#artistdetails"><%= artist.name %></a></h1><hr />

            <div class="row">
              <div class="col-sm-4 my-3">
                <a href="./<%= artist.shortname %>#artistdetails">
                  <img class="w-100 mb-1 " src="/images/artists/<%= artist.shortname %>.jpg" alt="Photo of <%= artist.title %>">
                  </a>

              </div>

              <div class="col-sm-8 my-3">
                <p><%- artist.summary %></p>
                <p><%- artist.description %></p><br />      

              </div>
            </div>

            <div class="row">
          
                <h3>Artwork</h3><hr />
                <%# Boxart %>
                <% if (boxart.reverse().length > 0) { %>
                  <%for (i=0; i < boxart.length; i ++){ %>
                        <div class="col-sm-2 mb-4 ">
                        <div class="pixgrid clearfix zoom">
                          <a href="/<%= boxart[i] %>"><img class="w-100" src="/images/fanart/<%= artist.shortname %>/<%= boxart[i] %>.jpg"></a>
                          </div>
                        </div>
  
                  <%}%>
                <% }  %>
              <%# /Boxart %>
            </div>
              </div>
        
          </section>


      <%# /Artists Details %>


        
<%# Import the footer %>
<%- include('templates/footer'); -%>
<%# /Import the footer %>