<%# Import the header%>
<%- include('templates/header'); -%>
<%# /Import the header%>

<section class="quotes-details" id="quotesdetails">
  <div class="container">
      <%# Artists Detail %>

      <h1><%- quotesDetail.shortname %> Winner: <%= quotesDetail.title %></h1><hr />
            <div class="row">
              <div class="col-sm-3">
                <a href="./<%= quotesDetail.shortname %>">
                  <img class="w-100" src="<%= quotesDetail.image %>" alt="Photo of <%= quotesDetail.title %>" />
                  </a>
                  <table class="table table-striped w-100">

                    <tbody>
                      <tr>
                        <th scope="row">Developer:</th>
                        <td><strong><%= quotesDetail.developer %></strong></td>
                      </tr>
                      <tr>
                        <th scope="row">Publisher:</th>
                        <td><strong><%- quotesDetail.publisher %></strong></td>
                      </tr>
                      <tr>
                        <th scope="row">Genre:</th>
                        <td><strong><%- quotesDetail.genre %></strong></td>
                      </tr>
                      <tr>
                        <th scope="row">Date:</th>
                        <td><strong><%- quotesDetail.releasedate %></strong></td>
                      </tr>
                      </tbody>
                  </table>

              </div>

              <div class="col-sm-6 ">
                <p class="text-justify"><%- quotesDetail.description %></p>
              </div>

              <div class="col-sm-3 text-center">
                <p>Honourable Mentions</p><hr />
                <div class="row">
                  <div class="col-sm-6">
                    <img class="w-100 zoom" src="/images/boxart/<%- quotesDetail.second %>.jpg" alt="Photo of <%= quotesDetail.second %>"/>
                  </div>
                  <div class="col-sm-6">
                    <img class="w-100 zoom" src="/images/boxart/<%- quotesDetail.third %>.jpg" alt="Photo of <%= quotesDetail.third %>"/>

                  </div>
                </div>

              </div>

            </div>
            
          </section>



<%# /Artists Detail %>


<%# Import the footer %>
<%- include('templates/footer'); -%>
<%# /Import the footer %>