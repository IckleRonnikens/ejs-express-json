<!DOCTYPE html>
<html>
<head>
  <title>Results for "<%= q %>"</title>
</head>
<body>
  <h1>Results for "<%= q %>"</h1>

  <% if (results.length === 0) { %>
    <p>No results found.</p>
  <% } else { %>
    <ul>
      <% results.forEach(item => { %>
        <li>
          <h3><%= item.title %></h3>
          <p><%= item.content %></p>
        </li>
      <% }) %>
    </ul>
  <% } %>

  <a href="/search">Back to search</a>
</body>
</html>
